# Supabase (créer un projet gratuit sur supabase.com)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# MapLibre / Protomaps (aucun token requis pour OSM)
